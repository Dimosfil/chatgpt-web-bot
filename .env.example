CHATGPT_WEB_PORT=3999
CHATGPT_WEB_HOST=0.0.0.0
CHATGPT_WEB_BACKEND=chatgpt_web
CHATGPT_WEB_AGENT_MODE=1

# DeepSeek native provider gateway.
# Set CHATGPT_WEB_BACKEND=deepseek to route compatible requests directly to DeepSeek.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT=120000
